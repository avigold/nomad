import { format } from 'date-fns';
import type { CountryStatus } from '../db/types';
import { ProgressBar } from './ProgressBar';

export interface Props {
  status: CountryStatus;
  isDefaultRule: boolean;
}

export function CountryCard({ status, isDefaultRule }: Props): JSX.Element {
  const {
    country,
    flag,
    daysUsed,
    maxDays,
    percentage,
    daysRemaining,
    windowStart,
    windowEnd,
  } = status;

  const dateRange = `${format(windowStart, 'MMM d, yyyy')} – ${format(windowEnd, 'MMM d, yyyy')}`;

  return (
    <div className="bg-gray-900 rounded-lg p-4 flex flex-col gap-2">
      <div className="flex items-center justify-between">
        <span className={`font-semibold text-lg ${isDefaultRule ? 'text-gray-500' : 'text-white'}`}>
          {flag} {country}
        </span>
        <span className="text-gray-300 text-sm">
          {daysUsed} / {maxDays} days
        </span>
      </div>
      <ProgressBar percentage={percentage} daysRemaining={daysRemaining} />
      <div className="flex items-center justify-between text-sm">
        {daysRemaining >= 0 ? (
          <span className="text-gray-300">{daysRemaining} days remaining</span>
        ) : (
          <span className="text-red-400">{Math.abs(daysRemaining)} days exceeded</span>
        )}
        <span className="text-gray-500">{dateRange}</span>
      </div>
    </div>
  );
}
```

