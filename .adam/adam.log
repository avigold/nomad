**Purpose**: Provides async CRUD helper functions for the trips table, encapsulating all Dexie write operations for trips in one place.

## Source Code
```
import { v4 as uuidv4 } from 'uuid';
import { db } from './database';
import type { Trip } from './types';

export async function addTrip(trip: Omit<Trip, 'id'>): Promise<string> {
  const id = uuidv4();
  await db.trips.add({ ...trip, id });
  return id;
}

export async function updateTrip(id: string, changes: Partial<Omit<Trip, 'id'>>): Promise<void> {
  await db.trips.update(id, changes);
}

export async function deleteTrip(id: string): Promise<void> {
  await db.trips.delete(id);
}

export async function replaceAllTrips(trips: Trip[]): Promise<void> {
  await db.transaction('rw', db.trips, async () => {
    await db.trips.clear();
    await db.trips.bulkAdd(trips);
  });
}
```

## Interface Specification
- functions: [{'signature': "addTrip(trip: Omit<Trip, 'id'>): Promise<string>", 'description': 'Generates a UUID, calls db.trips.add(), returns the new id'}, {'signature': "updateTrip(id: string, changes: Partial<Omit<Trip, 'id'>>): Promise<void>", 'description': 'Calls db.trips.update(id, changes)'}, {'signature': 'deleteTrip(id: string): Promise<void>', 'description': 'Calls db.trips.delete(id)'}, {'signature': 'replaceAllTrips(trips: Trip[]): Promise<void>', 'description': 'Runs a Dexie transaction: clears the trips table then bulk-adds the provided array — used by the JSON import feature'}]

